generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  name             String?
  role             Role           @default(STUDENT)
  image            String?
  isVerified       Boolean        @default(false)
  isBanned         Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  receivedMessages Message[]      @relation("ReceivedMessages")
  sentMessages     Message[]      @relation("SentMessages")
  notifications    Notification[]
  studentProfile   Student?
  tutorProfile     Tutor?
  savedTutors      SavedTutor[]
  theme            String?        @default("light")
}

model Student {
  id          String    @id @default(cuid())
  userId      String    @unique
  schoolLevel Level
  gradeLevel  Int?
  age         Int?
  schoolName  String?
  parentEmail String?
  parentId    String?
  subjects    String[]  @default([]) // Subjects the student wants to study: Mathematics, Science, Filipino, English
  attempts    Attempt[]
  bookings    Booking[]
  reviews     Review[]
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Tutor {
  id                 String             @id @default(cuid())
  userId             String             @unique
  introVideoUrl      String?
  bio                String?
  verificationStatus VerificationStatus @default(PENDING)
  headline           String?
  pricingPerHour     Float              @default(0)
  averageRating      Float?
  reviewCount        Int                @default(0)
  availability       Availability[]
  bookings           Booking[]
  certifications     Certification[]
  education          Education[]
  reviews            Review[]
  sessionNotes       SessionNote[]
  resources          Resource[]
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects           TutorSubject[]
  savedBy            SavedTutor[]
}

model Education {
  id             String @id @default(cuid())
  tutorId        String
  university     String
  degree         String
  specialization String
  yearStart      Int
  yearEnd        Int?
  tutor          Tutor  @relation(fields: [tutorId], references: [id], onDelete: Cascade)
}

model Certification {
  id             String @id @default(cuid())
  tutorId        String
  subject        String
  certificate    String
  issuedBy       String
  certificateUrl String?
  tutor          Tutor  @relation(fields: [tutorId], references: [id], onDelete: Cascade)
}

model Availability {
  id        String @id @default(cuid())
  tutorId   String
  dayOfWeek Int
  startTime String
  endTime   String
  tutor     Tutor  @relation(fields: [tutorId], references: [id], onDelete: Cascade)
}

model Subject {
  id     String         @id @default(cuid())
  name   String         @unique
  tests  Test[]
  tutors TutorSubject[]
}

model TutorSubject {
  tutorId   String
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])
  tutor     Tutor   @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@id([tutorId, subjectId])
}

model Booking {
  id        String       @id @default(cuid())
  studentId String
  tutorId   String
  date      DateTime
  meetLink  String?
  status    String       @default("PENDING")
  student   Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tutor     Tutor        @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  notes     SessionNote?
  review    Review?

  @@unique([studentId, tutorId, date])
}

model SessionNote {
  id        String   @id @default(cuid())
  bookingId String   @unique
  tutorId   String
  content   String   // Free-form session notes text
  subject   String?  // Subject covered: Mathematics, Science, Filipino, English
  topics    String[] @default([]) // Topics covered e.g. ["Algebra - Linear Equations", "Fractions"]
  skills    Json?    // Skill ratings: {"Confident": ["topic1"], "NeedsPractice": ["topic2"], "Struggling": ["topic3"]}
  homework  String?  // Homework assigned
  createdAt DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  tutor     Tutor    @relation(fields: [tutorId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  studentId String
  tutorId   String
  bookingId String?  @unique
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tutor     Tutor    @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
}

model SavedTutor {
  id        String   @id @default(cuid())
  userId    String
  tutorId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tutor     Tutor    @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@unique([userId, tutorId])
}

model Resource {
  id          String   @id @default(cuid())
  tutorId     String
  title       String
  description String?
  fileUrl     String
  fileType    String   @default("link")
  subject     String?
  level       Level?
  createdAt   DateTime @default(now())
  tutor       Tutor    @relation(fields: [tutorId], references: [id], onDelete: Cascade)
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  createdAt  DateTime @default(now())
  isRead     Boolean  @default(false)
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Test {
  id        String     @id @default(cuid())
  subjectId String
  level     Level
  attempts  Attempt[]
  questions Question[]
  subject   Subject    @relation(fields: [subjectId], references: [id])
}

model Question {
  id            String   @id @default(cuid())
  testId        String
  text          String
  options       String[]
  correctAnswer String
  test          Test     @relation(fields: [testId], references: [id])
}

model Attempt {
  id         String   @id @default(cuid())
  studentId  String
  testId     String?
  score      Int
  total      Int      @default(30)
  mastery    String?
  grade      String?
  strengths  Json
  weaknesses Json
  studyPlan  String?
  timestamp  DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  test       Test?    @relation(fields: [testId], references: [id])
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  usedAt    DateTime?

  @@index([email])
  @@index([token])
}

enum Role {
  STUDENT
  TUTOR
  ADMIN
  PARENT
}

enum Level {
  ELEMENTARY
  HIGH_SCHOOL
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}