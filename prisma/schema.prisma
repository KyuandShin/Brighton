generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  name             String?
  role             Role           @default(STUDENT)
  image            String?
  isVerified       Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  receivedMessages Message[]      @relation("ReceivedMessages")
  sentMessages     Message[]      @relation("SentMessages")
  notifications    Notification[]
  studentProfile   Student?
  tutorProfile     Tutor?
}

model Student {
  id          String    @id @default(cuid())
  userId      String    @unique
  schoolLevel Level
  gradeLevel  Int?
  age         Int?
  schoolName  String?
  parentEmail String?
  parentId    String?
  attempts    Attempt[]
  bookings    Booking[]
  reviews     Review[]
  user        User      @relation(fields: [userId], references: [id])
}

model Tutor {
  id                 String             @id @default(cuid())
  userId             String             @unique
  introVideoUrl      String?
  bio                String?
  verificationStatus VerificationStatus @default(PENDING)
  headline           String?
  pricingPerHour     Float              @default(0)
  availability       Availability[]
  bookings           Booking[]
  certifications     Certification[]
  education          Education[]
  reviews            Review[]
  sessionNotes       SessionNote[]
  user               User               @relation(fields: [userId], references: [id])
  subjects           TutorSubject[]
}

model Education {
  id             String @id @default(cuid())
  tutorId        String
  university     String
  degree         String
  specialization String
  yearStart      Int
  yearEnd        Int?
  tutor          Tutor  @relation(fields: [tutorId], references: [id])
}

model Certification {
  id             String @id @default(cuid())
  tutorId        String
  subject        String
  certificate    String
  issuedBy       String
  certificateUrl String?
  tutor          Tutor  @relation(fields: [tutorId], references: [id])
}

model Availability {
  id        String @id @default(cuid())
  tutorId   String
  dayOfWeek Int
  startTime String
  endTime   String
  tutor     Tutor  @relation(fields: [tutorId], references: [id])
}

model Subject {
  id     String         @id @default(cuid())
  name   String         @unique
  tests  Test[]
  tutors TutorSubject[]
}

model TutorSubject {
  tutorId   String
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])
  tutor     Tutor   @relation(fields: [tutorId], references: [id])

  @@id([tutorId, subjectId])
}

model Booking {
  id        String       @id @default(cuid())
  studentId String
  tutorId   String
  date      DateTime
  meetLink  String?
  status    String       @default("PENDING")
  student   Student      @relation(fields: [studentId], references: [id])
  tutor     Tutor        @relation(fields: [tutorId], references: [id])
  notes     SessionNote?
}

model SessionNote {
  id        String   @id @default(cuid())
  bookingId String   @unique
  tutorId   String
  content   String
  createdAt DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id])
  tutor     Tutor    @relation(fields: [tutorId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  studentId String
  tutorId   String
  rating    Int      @default(5)
  comment   String?
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id])
  tutor     Tutor    @relation(fields: [tutorId], references: [id])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  createdAt  DateTime @default(now())
  isRead     Boolean  @default(false)
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Test {
  id        String     @id @default(cuid())
  subjectId String
  level     Level
  attempts  Attempt[]
  questions Question[]
  subject   Subject    @relation(fields: [subjectId], references: [id])
}

model Question {
  id            String   @id @default(cuid())
  testId        String
  text          String
  options       String[]
  correctAnswer String
  test          Test     @relation(fields: [testId], references: [id])
}

model Attempt {
  id         String   @id @default(cuid())
  studentId  String
  testId     String
  score      Int
  weaknesses Json
  timestamp  DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [id])
  test       Test     @relation(fields: [testId], references: [id])
}

enum Role {
  STUDENT
  TUTOR
  ADMIN
  PARENT
}

enum Level {
  ELEMENTARY
  HIGH_SCHOOL
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}
